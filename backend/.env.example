# Security Settings
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# Database Options
# For SQLite locally, leave blank.
# For MySQL locally or in production, configure either DATABASE_URL or MYSQL_URL
# Example: mysql://root:password@127.0.0.1:3306/portfolio_db
DATABASE_URL=
MYSQL_URL=

# CORS Settings
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://yourportfolio.railway.app

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
# Use an App Password if using Gmail
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Pankaj Patel Portfolio <noreply@portfolio.com>
